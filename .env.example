# ============================================
# MedTach Environment Configuration
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# GitHub Content
GITHUB_CONTENT_REPO=YOUR_USER/medtach-content
GITHUB_CONTENT_BRANCH=main

# AI/ML (Optional)
OPENAI_API_KEY=sk-...  # For AI feedback enhancement

# Sync
CONTENT_SYNC_INTERVAL=3600000  # 1 hour in ms
MAX_CACHE_SIZE_MB=100

# Debug
DEBUG_MODE=false
FAIL_FAST=false

# Multiplayer (Optional)
MULTIPLAYER_ENABLED=false
MAX_PARTICIPANTS_PER_SESSION=5

# Analytics (Optional)
ANALYTICS_ENABLED=true
ERROR_REPORTING_ENABLED=true
