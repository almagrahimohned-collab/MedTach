      { id: 'cxr', name: 'Chest X-Ray', timeCost: 12, resultTime: 15, ordered: false, completed: false, isEssential: true, category: 'imaging', result: 'RLL consolidation with air bronchograms.' },
      { id: 'abg', name: 'Arterial Blood Gas', timeCost: 10, resultTime: 10, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'pH 7.44, pO2 58 - Type 1 respiratory failure' },
      { id: 'cbc', name: 'CBC with Differential', timeCost: 5, resultTime: 20, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'WBC 22.4, Bands 12%' },
      { id: 'blood_cultures', name: 'Blood Cultures ×2', timeCost: 8, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'Cultures drawn pre-antibiotics.' },
