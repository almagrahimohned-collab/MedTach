import { 
  ResourceState, createInitialResources, updateResourceState, 
  requestResource, releaseResource, getResourceStatusText, getLabDelay 
} from './ResourceManager';
import { 
  AchievementState, createAchievementState, checkAchievements, AchievementEvent 
} from './AchievementSystem';
import { 
  CareerState, createCareerState, addXp, recordShift, getLevelProgress, 
  getCurrentLevelInfo, getNextLevelInfo, LEVELS 
} from './CareerSystem';

// ==================== TYPES ====================

export interface Action {
  id: string;
  name: string;
  timeCost: number;
  resultTime: number;
  result?: string;
  ordered: boolean;
  completed: boolean;
  resultAt?: number;
  isEssential?: boolean;
  category?: string;
  resourceRequired?: string;
  resourceTime?: number;
}

export interface TreatmentPathway {
  correct: string[];
  acceptable: string[];
  wrongActions: string[];
  wrongActionsConsequence: string;
  criticalErrors: { action: string; consequence: string }[];
}

export interface DeteriorationStage {
  timer: number;
  stages: { time: number; event: string }[];
}

export interface DeteriorationPattern {
  withoutTreatment: DeteriorationStage;
  withPartialTreatment?: DeteriorationStage;
  withCorrectTreatment: DeteriorationStage;
}

export interface Patient {
  id: string;
  name: string;
  age: number;
  gender: string;
  complaint: string;
  priority: 'critical' | 'urgent' | 'stable';
  requiredActions: Action[];
  deteriorationTimer: number;
  currentState: string;
  completedActions: string[];
  status: 'waiting' | 'in-progress' | 'stable' | 'deteriorated' | 'transferred' | 'died';
  correctDiagnosis?: string;
  treatmentPathway?: TreatmentPathway;
  deteriorationPattern?: DeteriorationPattern;
  xpReward?: number;
  reputationImpact?: Record<string, number>;
  arrivalTime?: number;
  diagnosisTime?: number;
  treatedInTime?: boolean;
}

export interface ConsultRequest {
  id: string;
  from: string;
  patient: string;
  description: string;
  timeCost: number;
  repReward: number;
  accepted: boolean;
  completed: boolean;
}

export interface ShiftState {
  timeElapsed: number;
  focus: number;
  reputation: number;
  xp: number;
  patients: Patient[];
  consults: ConsultRequest[];
  events: string[];
  level: 'intern' | 'junior' | 'senior' | 'chief';
  shiftsCompleted: number;
  totalPatientsTreated: number;
  totalDeaths: number;
  correctDiagnoses: number;
  patientQueue: Patient[];
  shiftType: 'morning' | 'night' | 'weekend';
  // New integrated systems
  resources: ResourceState;
  achievements: AchievementState;
  career: CareerState;
  achievementEvents: AchievementEvent[];
  pendingAchievements: string[];
  shiftStartTime: number;
  patientsSaved: number;
  criticalSaved: number;
  diagnosesThisShift: string[];
  totalDiagnosisTime: number;
  diagnosisCount: number;
  massCasualtyActive: boolean;
  massCasualtyPatients: number;
}

// ==================== PATIENT GENERATION ====================

const PATIENT_NAMES_MALE = ['Ahmed', 'Hassan', 'Omar', 'Khalid', 'Ibrahim', 'Youssef', 'Ali', 'Mustafa', 'Tariq', 'Bilal', 'Mahmoud', 'Samir', 'Rashid', 'Nabil', 'Kareem'];
const PATIENT_NAMES_FEMALE = ['Fatima', 'Layla', 'Samira', 'Nour', 'Aisha', 'Mariam', 'Zainab', 'Huda', 'Amal', 'Sara', 'Nadia', 'Lina', 'Rania', 'Dalia', 'Mona'];
const LAST_NAMES = ['Al-Rashid', 'Al-Farsi', 'Al-Hashimi', 'Al-Qassim', 'Al-Sayed', 'Khan', 'Malik', 'Ahmed', 'Hassan', 'Omar', 'Ibrahim', 'Mahmoud', 'Khalil', 'Nasser', 'Saeed'];

const COMPLAINTS = {
  critical: [
    { complaint: 'Crushing chest pain radiating to left arm for 2 hours, diaphoretic', diagnosis: 'STEMI' },
    { complaint: 'Sudden severe tearing pain between shoulder blades, BP differential', diagnosis: 'Aortic Dissection' },
    { complaint: 'Sudden dyspnea, pleuritic chest pain, near-syncope, recent hip surgery', diagnosis: 'Massive PE' },
    { complaint: 'BP 72/40, confused, febrile 39.5°C, indwelling catheter ×2 weeks', diagnosis: 'Septic Shock - CAUTI' },
    { complaint: 'Sudden right hemiplegia and aphasia ×45 min, known AFib not anticoagulated', diagnosis: 'Acute Ischemic Stroke - LVO' },
    { complaint: 'Thunderclap headache "worst of life", vomiting, neck stiffness, BP 195/110', diagnosis: 'Subarachnoid Hemorrhage' },
    { complaint: 'Fever 39°C, rigors, RUQ pain, jaundiced, confused, hypotensive', diagnosis: 'Cholangitis with Septic Shock' },
    { complaint: 'Severe dyspnea, tracheal deviation, absent left breath sounds post-trauma', diagnosis: 'Tension Pneumothorax' },
  ],
  urgent: [
    { complaint: 'Fever 39.5°C, productive cough rust-colored sputum, pleuritic pain', diagnosis: 'Severe CAP' },
    { complaint: 'Severe dyspnea ×2h, known COPD on home O2, purulent sputum', diagnosis: 'COPD Exacerbation' },
    { complaint: 'Sharp pleuritic chest pain, worse lying flat, better sitting forward, febrile', diagnosis: 'Acute Pericarditis' },
    { complaint: 'Progressive dyspnea ×3 days, orthopnea, bilateral leg edema, known CAD', diagnosis: 'ADHF' },
    { complaint: 'Fever 38.5°C, acute confusion, dysuria, nursing home resident', diagnosis: 'Urosepsis' },
    { complaint: 'Sudden severe left pleuritic pain, dyspnea, tall thin build', diagnosis: 'Spontaneous Pneumothorax' },
