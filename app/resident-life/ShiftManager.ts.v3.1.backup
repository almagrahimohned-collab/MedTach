    { id: 'exam', name: 'Physical Examination', timeCost: 5, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'clinical', result: 'Physical exam completed.' },
  ];

  if (diagnosis.includes('STEMI') || diagnosis.includes('ACS') || diagnosis.includes('MI')) {
    baseActions.push(
      { id: 'ecg', name: '12-Lead ECG', timeCost: 8, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'investigation', result: 'ST elevation 4mm V1-V4, reciprocal ST depression II/III/aVF. Anteroseptal STEMI.' },
      { id: 'troponin', name: 'High-Sensitivity Troponin', timeCost: 5, resultTime: 25, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'hs-cTnI: 12.8 ng/mL (Normal <0.04) - Markedly elevated' },
      { id: 'aspirin', name: 'Aspirin 300mg PO', timeCost: 3, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'Antiplatelet initiated.' },
      { id: 'heparin', name: 'Unfractionated Heparin IV', timeCost: 8, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'Anticoagulation started.' },
      { id: 'cath_lab', name: 'Activate Cath Lab for PCI', timeCost: 10, resultTime: 30, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'Door-to-balloon: 52 min. DES to proximal LAD. TIMI 3 flow.', resourceRequired: 'ct', resourceTime: 45 },
    );
  } else if (diagnosis.includes('Dissection')) {
    baseActions.push(
      { id: 'ecg', name: '12-Lead ECG', timeCost: 8, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'investigation', result: 'Sinus tachycardia. LVH with strain. No ST elevation.' },
      { id: 'cxr', name: 'Chest X-Ray', timeCost: 12, resultTime: 15, ordered: false, completed: false, isEssential: true, category: 'imaging', result: 'Widened mediastinum >8cm. Loss of aortic knob.' },
      { id: 'bp_control', name: 'IV Beta-Blocker + Vasodilator', timeCost: 10, resultTime: 10, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'BP controlled to 120/75.' },
      { id: 'ct_angio', name: 'CT Angiography Chest/Abdomen', timeCost: 20, resultTime: 25, ordered: false, completed: false, isEssential: true, category: 'imaging', result: 'Type A dissection. Pericardial effusion. SURGICAL EMERGENCY.', resourceRequired: 'ct', resourceTime: 25 },
      { id: 'surgery_consult', name: 'Emergency CT Surgery Consult', timeCost: 8, resultTime: 15, ordered: false, completed: false, isEssential: true, category: 'consult', result: 'CT surgeon activated. OR prepared.' },
    );
  } else if (diagnosis.includes('PE') || diagnosis.includes('Pulmonary Embolism')) {
    baseActions.push(
      { id: 'ecg', name: '12-Lead ECG', timeCost: 8, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'investigation', result: 'Sinus tachycardia 125. S1Q3T3. Right axis deviation.' },
      { id: 'abg', name: 'Arterial Blood Gas', timeCost: 10, resultTime: 10, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'pH 7.32, pO2 52, Lactate 4.8 - Type 1 respiratory failure' },
      { id: 'echo_bedside', name: 'Bedside Echocardiogram', timeCost: 10, resultTime: 5, ordered: false, completed: false, isEssential: true, category: 'imaging', result: 'Dilated RV. McConnell sign. PAP 60mmHg.' },
      { id: 'thrombolysis', name: 'Systemic Thrombolysis (Alteplase)', timeCost: 15, resultTime: 30, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'tPA administered. Hemodynamics stabilizing.' },
    );
  } else if (diagnosis.includes('Sepsis') || diagnosis.includes('Septic') || diagnosis.includes('Shock')) {
    baseActions.push(
      { id: 'lactate', name: 'Serum Lactate', timeCost: 5, resultTime: 15, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'Lactate: 5.8 mmol/L (Normal <2.0)' },
      { id: 'blood_cultures', name: 'Blood Cultures ×2', timeCost: 8, resultTime: 0, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'Cultures drawn pre-antibiotics.' },
      { id: 'cbc', name: 'CBC with Differential', timeCost: 5, resultTime: 20, ordered: false, completed: false, isEssential: true, category: 'lab', result: 'WBC 19.8, Bands 15%, Plt 85' },
      { id: 'fluids_30ml_kg', name: 'IV Crystalloid 30mL/kg Bolus', timeCost: 20, resultTime: 60, ordered: false, completed: false, isEssential: true, category: 'treatment', result: '2.5L LR. MAP improved 52→58.' },
      { id: 'vasopressors', name: 'Norepinephrine IV Infusion', timeCost: 20, resultTime: 15, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'Norepi 0.1 mcg/kg/min. MAP now 68.' },
