      { id: 'lasix', name: 'IV Furosemide 40-80mg', timeCost: 8, resultTime: 30, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'Urine output 1.2L in 2h. Crackles decreasing.' },
