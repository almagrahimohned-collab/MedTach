  ],
};

function generatePatientName(gender: string): string {
  const firstNames = gender === 'male' ? PATIENT_NAMES_MALE : PATIENT_NAMES_FEMALE;
  return `${firstNames[Math.floor(Math.random() * firstNames.length)]} ${LAST_NAMES[Math.floor(Math.random() * LAST_NAMES.length)]}`;
}

function generateAge(): number {
  const weights = [{ range: [18, 35], weight: 20 }, { range: [36, 55], weight: 35 }, { range: [56, 75], weight: 30 }, { range: [76, 90], weight: 15 }];
  const totalWeight = weights.reduce((sum, w) => sum + w.weight, 0);
  let random = Math.random() * totalWeight;
  for (const w of weights) { random -= w.weight; if (random <= 0) return Math.floor(Math.random() * (w.range[1] - w.range[0] + 1)) + w.range[0]; }
  return 55;
}

function generatePatient(priority: 'critical' | 'urgent' | 'stable', id: string): Patient {
  const gender = Math.random() > 0.45 ? 'male' : 'female';
  const complaintData = COMPLAINTS[priority][Math.floor(Math.random() * COMPLAINTS[priority].length)];
  const age = generateAge();
  const baseDeterioration = priority === 'critical' ? 15 : priority === 'urgent' ? 40 : 90;

  return {
    id, name: generatePatientName(gender), age, gender,
    complaint: complaintData.complaint, priority,
    requiredActions: generateActionsForDiagnosis(complaintData.diagnosis),
    deteriorationTimer: baseDeterioration + Math.floor(Math.random() * 10),
    currentState: `Waiting in ER bed ${Math.floor(Math.random() * 20) + 1}`,
    completedActions: [], status: 'waiting',
    correctDiagnosis: complaintData.diagnosis,
    arrivalTime: undefined, diagnosisTime: undefined, treatedInTime: false,
  };
}

