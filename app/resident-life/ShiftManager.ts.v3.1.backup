// ==================== SHIFT CREATION ====================

export async function createInitialShift(
  level: string, 
  shiftType?: string, 
  careerState?: CareerState
): Promise<ShiftState> {
  const patientCount = level === 'intern' ? 4 : level === 'junior' ? 6 : level === 'senior' ? 10 : 15;
  const selectedShiftType = (shiftType || (Math.random() > 0.5 ? 'morning' : 'night')) as 'morning' | 'night' | 'weekend';

  const initialPatients: Patient[] = [];
  for (let i = 0; i < patientCount; i++) {
    const priorityRand = Math.random();
    const priority = priorityRand < 0.25 ? 'critical' : priorityRand < 0.6 ? 'urgent' : 'stable';
    initialPatients.push(generatePatient(priority, `p${i + 1}`));
  }

  const queuePatients: Patient[] = [];
  const queueSize = selectedShiftType === 'night' ? 3 : 5;
  for (let i = 0; i < queueSize; i++) {
    const priorityRand = Math.random();
    const priority = priorityRand < 0.3 ? 'critical' : priorityRand < 0.7 ? 'urgent' : 'stable';
    queuePatients.push(generatePatient(priority, `q${i + 1}`));
  }

  return {
    timeElapsed: 0,
    focus: 100,
    reputation: 500,
    xp: 0,
    patients: initialPatients,
    consults: [],
    events: [`${selectedShiftType === 'night' ? '🌙 Night' : '🌅 Morning'} shift started at ${selectedShiftType === 'night' ? '19' : '07'}:00. ${patientCount} patients waiting. ${queuePatients.length} more incoming.`],
    level: level as any,
    shiftsCompleted: 0,
    totalPatientsTreated: 0,
    totalDeaths: 0,
    correctDiagnoses: 0,
    patientQueue: queuePatients,
    shiftType: selectedShiftType,
    resources: createInitialResources(selectedShiftType),
    achievements: careerState?.xp ? { achievements: [], totalUnlocked: 0, totalXP: 0 } : createAchievementState(),
    career: careerState || createCareerState(),
    achievementEvents: [],
    pendingAchievements: [],
    shiftStartTime: Date.now(),
    patientsSaved: 0,
    criticalSaved: 0,
    diagnosesThisShift: [],
    totalDiagnosisTime: 0,
    diagnosisCount: 0,
    massCasualtyActive: false,
    massCasualtyPatients: 0,
  };
}

// ==================== SHIFT UPDATE ====================

export function updateShift(state: ShiftState): ShiftState {
  const newState = { ...state, timeElapsed: state.timeElapsed + 1 };
  const events = [...state.events];

  // Update resources
  newState.resources = updateResourceState(state.resources, 1);

  // Patient deterioration
  newState.patients = state.patients.map(p => {
    if (p.status === 'died' || p.status === 'transferred' || p.status === 'stable') return p;

    const newTimer = p.deteriorationTimer - 1;
    let newStatus = p.status;
    const completedEssential = p.requiredActions.filter(a => a.isEssential).every(a => a.completed);

    if (completedEssential && p.status !== 'died') {
      if (newStatus === 'waiting' || newStatus === 'in-progress' || newStatus === 'deteriorated') {
        newStatus = 'stable';
        events.push(`✅ ${p.name} is now stable with appropriate treatment.`);
        newState.patientsSaved++;
        if (p.priority === 'critical') newState.criticalSaved++;
      }
      return { ...p, deteriorationTimer: Math.max(0, newTimer + 15), status: newStatus, treatedInTime: true };
    }

    if (newTimer <= 0 && p.status !== 'stable') {
      newStatus = 'deteriorated';
      events.push(`⚠️ ${p.name} has deteriorated! Immediate action required!`);
    }
    if (newTimer <= -10 && newStatus === 'deteriorated') {
      newStatus = 'died';
      events.push(`💀 ${p.name} has died from delayed treatment.`);
      newState.totalDeaths++;
    }

    return { ...p, deteriorationTimer: newTimer, status: newStatus };
  });

  // Update pending results
  newState.patients = newState.patients.map(p => ({
    ...p,
    requiredActions: p.requiredActions.map(a => {
      if (a.ordered && !a.completed && a.resultAt && newState.timeElapsed >= a.resultAt) {
        return { ...a, completed: true };
      }
      return a;
    }),
  }));

  // New patient arrivals
  if (state.patientQueue.length > 0) {
    const arrivalIntervals = state.shiftType === 'night' ? [5, 10, 15, 20, 25] : [3, 5, 7, 10, 12, 15, 18, 20];
    if (arrivalIntervals.includes(state.timeElapsed) || state.timeElapsed % 8 === 0) {
      const newPatient = { ...state.patientQueue[0], arrivalTime: state.timeElapsed };
      newState.patients = [...newState.patients, newPatient];
      newState.patientQueue = state.patientQueue.slice(1);
      const emoji = newPatient.priority === 'critical' ? '🚨' : newPatient.priority === 'urgent' ? '⚠️' : '🟢';
      events.push(`${emoji} New arrival: ${newPatient.name}, ${newPatient.age}${newPatient.gender === 'male' ? 'M' : 'F'} - ${newPatient.complaint.substring(0, 50)}...`);
    }
  }

  // Refill queue
  if (state.timeElapsed % 10 === 0 && state.timeElapsed > 0 && newState.patientQueue.length < 3) {
    const priorityRand = Math.random();
    const priority = priorityRand < 0.2 ? 'critical' : priorityRand < 0.55 ? 'urgent' : 'stable';
    const id = `q${state.timeElapsed}_${Math.floor(Math.random() * 1000)}`;
    newState.patientQueue = [...newState.patientQueue, generatePatient(priority, id)];
  }

  // Mass casualty event (rare)
  if (state.timeElapsed === 30 && Math.random() < 0.15 && !state.massCasualtyActive) {
    newState.massCasualtyActive = true;
    const count = 6 + Math.floor(Math.random() * 6);
    events.push(`🚨 MASS CASUALTY: Bus accident! ${count} patients incoming!`);
    for (let i = 0; i < count; i++) {
      const priority = i < 3 ? 'critical' : i < 7 ? 'urgent' : 'stable';
      newState.patientQueue = [generatePatient(priority, `mc_${i}`), ...newState.patientQueue];
    }
    newState.massCasualtyPatients = count;
  }

  // Consults
  if (state.timeElapsed % 10 === 0 && state.timeElapsed > 0 && state.timeElapsed % 20 !== 0) {
    const departments = ['Surgery', 'OB/GYN', 'Pediatrics', 'Orthopedics', 'Neurology'];
    const dept = departments[Math.floor(Math.random() * departments.length)];
    const consult: ConsultRequest = {
      id: `c${state.timeElapsed}`, from: dept, patient: `Patient in ${dept}`,
      description: `Urgent evaluation requested`,
      timeCost: 20, repReward: 15, accepted: false, completed: false,
    };
    newState.consults = [...state.consults, consult];
    events.push(`📞 Consult from ${dept}: ${consult.description}`);
  }

  // Fatigue
  if (state.timeElapsed % 40 === 0 && state.timeElapsed > 0) {
    newState.focus = Math.max(15, state.focus - 4);
  }

  // Night shift effects
  if (state.shiftType === 'night' && state.timeElapsed % 15 === 0 && state.timeElapsed > 0) {
    events.push('🌙 Night shift: Reduced staffing. Lab results delayed 40%.');
  }

  newState.events = events;
  return newState;
}

// ==================== ACTIONS ====================

export function performAction(state: ShiftState, patientId: string, actionId: string): ShiftState {
  const patient = state.patients.find(p => p.id === patientId);
  if (!patient) return state;

  const action = patient.requiredActions.find(a => a.id === actionId);
  if (!action) return state;

  const timeCost = action.timeCost || 5;
  const resultTime = action.resultTime || 0;
  
  // Apply lab delay for night shift
  const labMultiplier = action.category === 'lab' ? getLabDelay(state.shiftType) : 1;
  const adjustedResultTime = Math.floor(resultTime * labMultiplier);

  let actionOutcome = '';
  let reputationChange = 0;
  const newAchievementEvents: AchievementEvent[] = [];

  // Check treatment pathway
  const pathway = patient.treatmentPathway;
  if (pathway?.criticalErrors) {
    const criticalError = pathway.criticalErrors.find(e => e.action === actionId);
    if (criticalError) {
      actionOutcome = `⚠️ CRITICAL ERROR: ${criticalError.consequence}`;
      reputationChange = -40;
    }
  }

  if (pathway?.wrongActions?.includes(actionId)) {
    actionOutcome = `⚠️ ${pathway.wrongActionsConsequence}`;
    reputationChange = -20;
  }

  // Track diagnosis
  if (actionId === 'history' || actionId === 'exam') {
    if (!patient.diagnosisTime) {
      patient.diagnosisTime = state.timeElapsed;
      newState.diagnosisCount++;
      newState.totalDiagnosisTime += state.timeElapsed - (patient.arrivalTime || 0);
    }
  }

  // Track achievement events
  if (patient.correctDiagnosis?.includes('STEMI')) {
    newAchievementEvents.push({ type: 'diagnosis', data: 'STEMI' });
    newAchievementEvents.push({ type: 'rapid_treatment' });
  }
  if (patient.correctDiagnosis?.includes('Stroke')) {
    newAchievementEvents.push({ type: 'stroke_treated' });
  }
  if (patient.correctDiagnosis?.includes('Sepsis') || patient.correctDiagnosis?.includes('Septic')) {
    newAchievementEvents.push({ type: 'sepsis_bundle_complete' });
  }
  if (patient.correctDiagnosis?.includes('Dissection')) {
    newAchievementEvents.push({ type: 'diagnosis', data: 'Aortic Dissection' });
    newAchievementEvents.push({ type: 'rare_diagnosis' });
  }
  if (patient.correctDiagnosis?.includes('PE') || patient.correctDiagnosis?.includes('Embolism')) {
    newAchievementEvents.push({ type: 'pe_thrombolysed' });
  }
  if (patient.correctDiagnosis?.includes('SAH') || patient.correctDiagnosis?.includes('Subarachnoid')) {
    newAchievementEvents.push({ type: 'rare_diagnosis' });
  }

  const newEvents = [...state.events];
  if (actionOutcome) newEvents.push(actionOutcome);

  const newTimeElapsed = state.timeElapsed + timeCost;

  return {
    ...state,
    timeElapsed: newTimeElapsed,
    focus: Math.max(5, state.focus - 2),
    reputation: state.reputation + reputationChange,
    achievementEvents: [...state.achievementEvents, ...newAchievementEvents],
    patients: state.patients.map(p => {
      if (p.id !== patientId) return p;
      return {
        ...p,
        completedActions: [...p.completedActions, actionId],
        requiredActions: p.requiredActions.map(a => {
          if (a.id !== actionId) return a;
          const resultAt = a.resultTime > 0 ? newTimeElapsed + adjustedResultTime : newTimeElapsed;
          return { ...a, ordered: true, resultAt, completed: a.resultTime === 0, result: a.result || `${a.name} completed.` };
        }),
        status: 'in-progress' as const,
        deteriorationTimer: Math.max(1, p.deteriorationTimer + (p.priority === 'critical' ? 5 : 10)),
      };
    }),
    events: [...newEvents, `[${state.timeElapsed}m] ${action.name} for ${patient.name}${actionOutcome ? ' - ' + actionOutcome : ''}`],
  };
}

export function acceptConsult(state: ShiftState, consultId: string): ShiftState {
  return {
    ...state,
    consults: state.consults.map(c => c.id === consultId ? { ...c, accepted: true } : c),
    reputation: state.reputation + 15,
    xp: state.xp + 20,
    events: [...state.events, `✅ Accepted consult from ${state.consults.find(c => c.id === consultId)?.from}`],
  };
}

// ==================== SHIFT END ====================

export function evaluateShift(state: ShiftState): {
  survived: number; died: number; consultsAccepted: number;
  xpEarned: number; reputationChange: number; accuracy: number;
  bonusXP: number; avgDiagnosisTime: number; achievementsUnlocked: string[];
  levelUp: boolean; newLevel: string | null; careerProgress: number;
} {
  const survived = state.patients.filter(p => p.status !== 'died').length;
  const died = state.patients.filter(p => p.status === 'died').length;
  const consultsAccepted = state.consults.filter(c => c.accepted).length;
  const totalPatients = state.patients.length;

  // Calculate accuracy
  let correctDecisions = 0;
  state.patients.forEach(p => {
    const pathway = p.treatmentPathway;
    if (!pathway || p.status === 'died') return;
    const correctActions = pathway.correct || [];
    const completedCorrect = correctActions.filter(a => p.completedActions.includes(a)).length;
    if (completedCorrect >= correctActions.length * 0.6) correctDecisions++;
  });
  const accuracy = totalPatients > 0 ? (correctDecisions / totalPatients) * 100 : 0;

  // Average diagnosis time
  const avgDiagnosisTime = state.diagnosisCount > 0 ? state.totalDiagnosisTime / state.diagnosisCount : 0;

  // Calculate XP
  const baseXP = Math.floor(survived * 50 + state.reputation * 0.5 + accuracy * 3);
  const deathPenalty = died * 30;
  const bonusXP = Math.max(0, baseXP - deathPenalty);

  // Check achievements
  const shiftEvents: AchievementEvent[] = [
    ...state.achievementEvents,
    { type: 'shift_complete', data: { deaths: died, accuracy, avgDiagnosisTime, shiftType: state.shiftType, criticalSaved: state.criticalSaved } },
    { type: 'patient_saved' },
    ...Array(survived).fill({ type: 'patient_treated' }),
  ];

  let updatedAchievements = state.achievements;
  const unlockedNames: string[] = [];
  shiftEvents.forEach(event => {
    const result = checkAchievements(updatedAchievements, event);
    updatedAchievements = result.updatedState;
    result.newlyUnlocked.forEach(ach => {
      unlockedNames.push(`${ach.icon} ${ach.name} (+${ach.xpReward} XP)`);
    });
  });

  // Career progression
  const totalXP = bonusXP + updatedAchievements.totalXP;
  let updatedCareer = state.career;
  
  // Record shift
  updatedCareer = recordShift(updatedCareer, {
    patientsTreated: totalPatients,
    deaths: died,
    accuracy,
    correctDiagnoses: correctDecisions,
    shiftType: state.shiftType,
    specificStats: {
      fastestDiagnosis: state.diagnosisCount > 0 ? Math.min(...state.patients.filter(p => p.diagnosisTime).map(p => p.diagnosisTime || 999)) : 999,
      patientsSaved: survived,
    },
  });

  // Add XP
  updatedCareer = addXp(updatedCareer, totalXP);

  // Check level up
  const oldLevel = state.career.level;
  const newLevel = updatedCareer.level;
  const levelUp = oldLevel !== newLevel;

  return {
    survived, died, consultsAccepted,
    xpEarned: bonusXP,
    reputationChange: died > 0 ? -died * 30 : Math.floor(survived * 10),
    accuracy,
    bonusXP: totalXP,
    avgDiagnosisTime,
    achievementsUnlocked: unlockedNames,
    levelUp,
    newLevel: levelUp ? newLevel : null,
    careerProgress: getLevelProgress(updatedCareer),
  };
}

// ==================== UTILITY ====================

export function formatTime(min: number): string {
  const baseHour = 7;
  const h = (Math.floor(min / 60) + baseHour) % 24;
  const m = min % 60;
  return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
}

export function getPatientStatusColor(status: string): string {
  switch (status) {
    case 'critical': return '#EF4444';
    case 'urgent': return '#F59E0B';
    case 'stable': return '#10B981';
    case 'died': return '#6B7280';
    case 'deteriorated': return '#DC2626';
    default: return '#94A3B8';
  }
}

export function getResourceSummary(state: ShiftState): string[] {
  return getResourceStatusText(state.resources);
}
