      { id: 'steroids', name: 'IV Methylprednisolone 125mg', timeCost: 5, resultTime: 60, ordered: false, completed: false, isEssential: true, category: 'treatment', result: 'Reduces treatment failure by 50%.' },
    );
  } else if (diagnosis.includes('Pneumonia') || diagnosis.includes('CAP')) {
