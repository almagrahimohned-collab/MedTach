import React, { useState, useEffect, useRef } from 'react';
import {
  StyleSheet, Text, View, Pressable, ScrollView, Modal, FlatList,
} from 'react-native';
import { useRouter } from 'expo-router';
import { Ionicons } from '@expo/vector-icons';
import { useStore } from '../../src/store';
import { ShiftState, createInitialShift, updateShift, performAction, acceptConsult, Patient, Action, ConsultRequest } from './ShiftManager';

export default function ResidentLife() {
  const router = useRouter();
  const { addPoints } = useStore();
  const [state, setState] = useState<ShiftState>(createInitialShift('junior'));
  const [selectedPatient, setSelectedPatient] = useState<Patient | null>(null);
  const [showPatientModal, setShowPatientModal] = useState(false);
  const [showReport, setShowReport] = useState(false);
  const [gameStarted, setGameStarted] = useState(false);
  const [gameOver, setGameOver] = useState(false);
  const timerRef = useRef<NodeJS.Timeout | null>(null);

  useEffect(() => {
    if (gameStarted && !gameOver) {
      timerRef.current = setInterval(() => {
        setState(prev => {
          const updated = updateShift(prev);
          const alive = updated.patients.filter(p => p.status !== 'died');
          if (alive.length === 0 || updated.focus <= 0) {
            setGameOver(true);
            if (timerRef.current) clearInterval(timerRef.current);
          }
          return updated;
        });
      }, 1000);
      return () => { if (timerRef.current) clearInterval(timerRef.current); };
    }
  }, [gameStarted, gameOver]);

  const handleAction = (patientId: string, action: Action) => {
    setState(prev => performAction(prev, patientId, action.id));
    setShowPatientModal(false);
  };

  const handleAcceptConsult = (consultId: string) => {
    setState(prev => acceptConsult(prev, consultId));
  };

  const handleEndShift = () => {
    if (timerRef.current) clearInterval(timerRef.current);
    const survived = state.patients.filter(p => p.status !== 'died').length;
    const bonus = survived * 50 + state.reputation;
    addPoints(bonus);
    setGameOver(true);
    setShowReport(true);
  };

  const formatTime = (min: number) => {
    const h = Math.floor(min / 60) + 7;
    const m = min % 60;
    return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
  };

  if (!gameStarted) {
    return (
      <View style={styles.container}>
        <View style={styles.welcomeCard}>
          <Ionicons name="medkit" size={60} color="#EF4444" />
          <Text style={styles.welcomeTitle}>Resident Life</Text>
          <Text style={styles.welcomeSub}>Emergency Department Shift</Text>
          <View style={styles.welcomeInfo}>
            <View style={styles.infoRow}>
              <Ionicons name="people" size={16} color="#94A3B8" />
              <Text style={styles.infoText}>{state.patients.length} patients waiting</Text>
            </View>
            <View style={styles.infoRow}>
              <Ionicons name="time" size={16} color="#94A3B8" />
              <Text style={styles.infoText}>12-hour shift (approx 72 min)</Text>
            </View>
            <View style={styles.infoRow}>
              <Ionicons name="star" size={16} color="#F59E0B" />
              <Text style={styles.infoText}>Junior Resident</Text>
            </View>
          </View>
          <Pressable style={styles.startBtn} onPress={() => setGameStarted(true)}>
            <Text style={styles.startBtnText}>Start Shift</Text>
          </Pressable>
        </View>
      </View>
    );
  }

  if (gameOver && showReport) {
    const survived = state.patients.filter(p => p.status !== 'died').length;
    const died = state.patients.filter(p => p.status === 'died').length;
    return (
      <View style={styles.container}>
        <View style={styles.reportCard}>
          <Ionicons name="clipboard" size={60} color="#38BDF8" />
          <Text style={styles.reportTitle}>Shift Report</Text>
          <Text style={styles.reportScore}>{state.xp + survived * 50} XP</Text>
          <View style={styles.reportStats}>
            <Text style={styles.reportText}>✅ {survived} survived</Text>
            <Text style={styles.reportText}>❌ {died} died</Text>
            <Text style={styles.reportText}>📞 {state.consults.filter(c => c.accepted).length} consults</Text>
            <Text style={styles.reportText}>⭐ {state.reputation} reputation</Text>
          </View>
          <Pressable style={styles.startBtn} onPress={() => {
            setState(createInitialShift('junior'));
            setGameOver(false);
            setGameStarted(true);
            setShowReport(false);
          }}>
            <Text style={styles.startBtnText}>Next Shift</Text>
          </Pressable>
          <Pressable style={styles.backBtn} onPress={() => router.back()}>
            <Text style={styles.backBtnText}>Dashboard</Text>
          </Pressable>
        </View>
      </View>
    );
  }

  const criticalPatients = state.patients.filter(p => p.status === 'waiting' && p.priority === 'critical');
  const urgentPatients = state.patients.filter(p => p.status === 'waiting' && p.priority === 'urgent');
  const stablePatients = state.patients.filter(p => p.status === 'waiting' && p.priority === 'stable');
  const donePatients = state.patients.filter(p => p.status === 'stable' || p.status === 'transferred');
  const deadPatients = state.patients.filter(p => p.status === 'died');

  return (
    <View style={styles.container}>
      {/* Header */}
      <View style={styles.header}>
        <Pressable onPress={() => { if (timerRef.current) clearInterval(timerRef.current); router.back(); }}>
          <Ionicons name="close" size={22} color="#94A3B8" />
        </Pressable>
        <View style={styles.headerInfo}>
          <Text style={styles.headerTitle}>ER Shift</Text>
          <Text style={styles.headerTime}>{formatTime(state.timeElapsed)}</Text>
        </View>
        <View style={styles.headerStats}>
          <Text style={styles.focusText}>⚡{state.focus}%</Text>
          <Text style={styles.repText}>⭐{state.reputation}</Text>
        </View>
      </View>

      <ScrollView style={styles.content} showsVerticalScrollIndicator={false}>
        {/* Critical Patients */}
        {criticalPatients.length > 0 && (
          <View style={styles.section}>
            <Text style={styles.sectionTitle}>🔴 Critical ({criticalPatients.length})</Text>
            {criticalPatients.map(p => (
              <Pressable key={p.id} style={[styles.patientCard, styles.criticalCard]} onPress={() => { setSelectedPatient(p); setShowPatientModal(true); }}>
                <View style={styles.patientInfo}>
                  <Text style={styles.patientName}>{p.name}, {p.age}{p.gender === 'male' ? 'M' : 'F'}</Text>
                  <Text style={styles.patientComplaint}>{p.complaint}</Text>
                  <Text style={styles.patientTimer}>⏱ Deteriorates in {p.deteriorationTimer}min</Text>
                </View>
                <Ionicons name="chevron-forward" size={18} color="#EF4444" />
              </Pressable>
            ))}
          </View>
        )}

        {/* Urgent Patients */}
        {urgentPatients.length > 0 && (
          <View style={styles.section}>
            <Text style={styles.sectionTitle}>🟡 Urgent ({urgentPatients.length})</Text>
            {urgentPatients.map(p => (
              <Pressable key={p.id} style={[styles.patientCard, styles.urgentCard]} onPress={() => { setSelectedPatient(p); setShowPatientModal(true); }}>
                <View style={styles.patientInfo}>
                  <Text style={styles.patientName}>{p.name}, {p.age}{p.gender === 'male' ? 'M' : 'F'}</Text>
                  <Text style={styles.patientComplaint}>{p.complaint}</Text>
                </View>
                <Ionicons name="chevron-forward" size={18} color="#F59E0B" />
              </Pressable>
            ))}
          </View>
        )}

        {/* Stable Patients */}
        {stablePatients.length > 0 && (
          <View style={styles.section}>
            <Text style={styles.sectionTitle}>🟢 Stable ({stablePatients.length})</Text>
            {stablePatients.map(p => (
              <Pressable key={p.id} style={styles.patientCard} onPress={() => { setSelectedPatient(p); setShowPatientModal(true); }}>
                <View style={styles.patientInfo}>
                  <Text style={styles.patientName}>{p.name}, {p.age}{p.gender === 'male' ? 'M' : 'F'}</Text>
                  <Text style={styles.patientComplaint}>{p.complaint}</Text>
                </View>
                <Ionicons name="chevron-forward" size={18} color="#10B981" />
              </Pressable>
            ))}
          </View>
        )}

        {/* Done */}
        {donePatients.length > 0 && (
          <View style={styles.section}>
            <Text style={styles.sectionTitle}>✅ Done ({donePatients.length})</Text>
          </View>
        )}
        {deadPatients.length > 0 && (
          <View style={styles.section}>
            <Text style={[styles.sectionTitle, { color: '#EF4444' }]}>💀 Deceased ({deadPatients.length})</Text>
          </View>
        )}

        {/* Consults */}
        {state.consults.filter(c => !c.accepted).length > 0 && (
          <View style={styles.section}>
            <Text style={styles.sectionTitle}>📞 Consults</Text>
            {state.consults.filter(c => !c.accepted).map(c => (
              <Pressable key={c.id} style={styles.consultCard} onPress={() => handleAcceptConsult(c.id)}>
                <View style={styles.patientInfo}>
                  <Text style={styles.consultFrom}>From: {c.from}</Text>
                  <Text style={styles.consultDesc}>{c.description}</Text>
                  <Text style={styles.consultReward}>⭐ +{c.repReward} rep • ⏱ {c.timeCost}min</Text>
                </View>
                <Ionicons name="add-circle" size={24} color="#38BDF8" />
              </Pressable>
            ))}
          </View>
        )}

        {/* Events */}
        <View style={styles.section}>
          <Text style={styles.sectionTitle}>📝 Events</Text>
          {state.events.slice(-10).map((event, i) => (
            <Text key={i} style={styles.eventText}>{event}</Text>
          ))}
        </View>
      </ScrollView>

      {/* End Shift Button */}
      <Pressable style={styles.endShiftBtn} onPress={handleEndShift}>
        <Text style={styles.endShiftText}>End Shift & Get Report</Text>
      </Pressable>

      {/* Patient Modal */}
      <Modal visible={showPatientModal} transparent animationType="slide">
        <View style={styles.modalOverlay}>
          <View style={styles.modalContent}>
            {selectedPatient && (
              <>
                <Text style={styles.modalTitle}>{selectedPatient.name}</Text>
                <Text style={styles.modalSub}>{selectedPatient.age}{selectedPatient.gender === 'male' ? 'M' : 'F'} • {selectedPatient.complaint}</Text>
                <Text style={styles.modalPriority}>
                  {selectedPatient.priority === 'critical' ? '🔴 Critical' : selectedPatient.priority === 'urgent' ? '🟡 Urgent' : '🟢 Stable'}
                  {' • ⏱ '}{selectedPatient.deteriorationTimer}min
                </Text>
                
                <Text style={styles.actionTitle}>Required Actions:</Text>
                {selectedPatient.requiredActions.map(action => (
                  <Pressable
                    key={action.id}
                    style={[styles.actionBtn, action.completed && styles.actionDone]}
                    onPress={() => handleAction(selectedPatient.id, action)}
                    disabled={action.completed}
                  >
                    <Ionicons name={action.completed ? 'checkmark-circle' : 'add-circle'} size={20} color={action.completed ? '#10B981' : '#38BDF8'} />
                    <View style={{ flex: 1 }}>
                      <Text style={styles.actionName}>{action.name}</Text>
                      <Text style={styles.actionTime}>⏱ {action.timeCost}min {action.resultTime > 0 ? `• Result in ${action.resultTime}min` : ''}</Text>
                    </View>
                  </Pressable>
                ))}
                
                <Pressable style={styles.closeBtn} onPress={() => setShowPatientModal(false)}>
                  <Text style={styles.closeBtnText}>Close</Text>
                </Pressable>
              </>
            )}
          </View>
        </View>
      </Modal>
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#0A0E1A' },
  welcomeCard: { flex: 1, justifyContent: 'center', alignItems: 'center', padding: 40, gap: 16 },
  welcomeTitle: { color: '#F8FAFC', fontSize: 28, fontWeight: '800' },
  welcomeSub: { color: '#94A3B8', fontSize: 16 },
  welcomeInfo: { gap: 8, marginVertical: 10 },
  infoRow: { flexDirection: 'row', alignItems: 'center', gap: 8 },
  infoText: { color: '#E2E8F0', fontSize: 14 },
  startBtn: { backgroundColor: '#EF4444', paddingHorizontal: 40, paddingVertical: 16, borderRadius: 16 },
  startBtnText: { color: '#FFF', fontSize: 17, fontWeight: '700' },
  backBtn: { marginTop: 8 },
  backBtnText: { color: '#94A3B8', fontSize: 14 },
  reportCard: { flex: 1, justifyContent: 'center', alignItems: 'center', padding: 40, gap: 14 },
  reportTitle: { color: '#F8FAFC', fontSize: 24, fontWeight: '800' },
  reportScore: { color: '#F59E0B', fontSize: 40, fontWeight: '800' },
  reportStats: { gap: 6 },
  reportText: { color: '#E2E8F0', fontSize: 15 },
  header: { flexDirection: 'row', alignItems: 'center', padding: 14, paddingTop: 20, backgroundColor: '#1A1F2E', borderBottomWidth: 1, borderBottomColor: '#1E293B', gap: 10 },
  headerInfo: { flex: 1 },
  headerTitle: { color: '#F8FAFC', fontSize: 16, fontWeight: '700' },
  headerTime: { color: '#94A3B8', fontSize: 12 },
  headerStats: { flexDirection: 'row', gap: 12 },
  focusText: { color: '#F59E0B', fontSize: 13, fontWeight: '700' },
  repText: { color: '#38BDF8', fontSize: 13, fontWeight: '700' },
  content: { flex: 1, padding: 12 },
  section: { marginBottom: 16 },
  sectionTitle: { color: '#F8FAFC', fontSize: 14, fontWeight: '700', marginBottom: 8 },
  patientCard: { backgroundColor: '#1E293B', padding: 14, borderRadius: 12, flexDirection: 'row', alignItems: 'center', borderWidth: 1, borderColor: '#334155', marginBottom: 8 },
  criticalCard: { borderColor: '#EF444440' },
  urgentCard: { borderColor: '#F59E0B40' },
  patientInfo: { flex: 1 },
  patientName: { color: '#F8FAFC', fontSize: 14, fontWeight: '600' },
  patientComplaint: { color: '#94A3B8', fontSize: 12, marginTop: 2 },
  patientTimer: { color: '#EF4444', fontSize: 11, marginTop: 4 },
  consultCard: { backgroundColor: '#1E293B', padding: 14, borderRadius: 12, flexDirection: 'row', alignItems: 'center', borderWidth: 1, borderColor: '#38BDF840', marginBottom: 8 },
  consultFrom: { color: '#38BDF8', fontSize: 13, fontWeight: '600' },
  consultDesc: { color: '#E2E8F0', fontSize: 12, marginTop: 2 },
  consultReward: { color: '#F59E0B', fontSize: 11, marginTop: 4 },
  eventText: { color: '#64748B', fontSize: 11, paddingVertical: 1 },
  endShiftBtn: { backgroundColor: '#10B981', margin: 12, padding: 16, borderRadius: 14, alignItems: 'center' },
  endShiftText: { color: '#FFF', fontSize: 15, fontWeight: '700' },
  modalOverlay: { flex: 1, backgroundColor: 'rgba(0,0,0,0.7)', justifyContent: 'flex-end' },
  modalContent: { backgroundColor: '#1E293B', padding: 20, borderTopLeftRadius: 20, borderTopRightRadius: 20, maxHeight: '70%' },
  modalTitle: { color: '#F8FAFC', fontSize: 20, fontWeight: '700' },
  modalSub: { color: '#94A3B8', fontSize: 13, marginTop: 4 },
  modalPriority: { color: '#F59E0B', fontSize: 12, fontWeight: '600', marginTop: 8 },
  actionTitle: { color: '#94A3B8', fontSize: 12, fontWeight: '700', marginTop: 16, marginBottom: 8 },
  actionBtn: { flexDirection: 'row', alignItems: 'center', padding: 12, borderBottomWidth: 1, borderBottomColor: '#334155', gap: 10 },
  actionDone: { opacity: 0.5 },
  actionName: { color: '#F8FAFC', fontSize: 14, fontWeight: '600' },
  actionTime: { color: '#64748B', fontSize: 11, marginTop: 2 },
  closeBtn: { backgroundColor: '#334155', padding: 14, borderRadius: 12, alignItems: 'center', marginTop: 16 },
  closeBtnText: { color: '#E2E8F0', fontWeight: '600' },
});
