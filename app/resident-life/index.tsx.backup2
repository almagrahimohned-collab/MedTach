  // Events
  eventText: { color: '#64748B', fontSize: 10, paddingVertical: 1 },

  // End button
  endBtn: { backgroundColor: '#10B981', margin: 10, padding: 14, borderRadius: 12, alignItems: 'center' },
  endBtnText: { color: '#FFF', fontSize: 14, fontWeight: '700' },

  // Modal
  modalOverlay: { flex: 1, backgroundColor: 'rgba(0,0,0,0.7)', justifyContent: 'flex-end' },
  modalContent: { backgroundColor: '#1E293B', padding: 20, borderTopLeftRadius: 20, borderTopRightRadius: 20, maxHeight: '85%' },
  modalTitle: { color: '#F8FAFC', fontSize: 18, fontWeight: '700' },
  modalSub: { color: '#94A3B8', fontSize: 12, marginTop: 4 },
  modalTimer: { color: '#EF4444', fontSize: 12, fontWeight: '600', marginTop: 6 },
  priorityTag: { fontSize: 11, fontWeight: '600' },
  diagCorrect: { color: '#10B981', fontSize: 12, fontWeight: '600', marginTop: 6 },
  diagWrong: { color: '#EF4444', fontSize: 12, fontWeight: '600', marginTop: 6 },
  diagHint: { color: '#94A3B8', fontSize: 12, marginTop: 8 },
  diagnoseBtn: { flexDirection: 'row', alignItems: 'center', justifyContent: 'center', gap: 8, backgroundColor: '#8B5CF620', padding: 12, borderRadius: 10, borderWidth: 1, borderColor: '#8B5CF6', marginTop: 10 },
  diagnoseBtnText: { color: '#A78BFA', fontSize: 14, fontWeight: '600' },

  // Criteria
  criteriaInfo: { backgroundColor: '#0F172A', padding: 10, borderRadius: 8, marginTop: 10, borderWidth: 1, borderColor: '#334155' },
  criteriaTitle: { color: '#64748B', fontSize: 10, fontWeight: '600', marginBottom: 4 },
  criteriaText: { color: '#E2E8F0', fontSize: 11, lineHeight: 16 },

  // Actions
  actionSectionTitle: { color: '#94A3B8', fontSize: 12, fontWeight: '700', marginTop: 16, marginBottom: 8 },
  actionBtn: { flexDirection: 'row', alignItems: 'center', padding: 10, borderBottomWidth: 1, borderBottomColor: '#334155', gap: 8 },
  actionDone: { opacity: 0.5 },
  actionTreatment: { backgroundColor: '#F59E0B05' },
  actionName: { color: '#F8FAFC', fontSize: 13, fontWeight: '600' },
  treatmentTag: { color: '#F59E0B', fontSize: 8, fontWeight: '700', backgroundColor: '#F59E0B20', paddingHorizontal: 4, paddingVertical: 1, borderRadius: 3 },
