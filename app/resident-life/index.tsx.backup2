  actionResult: { color: '#10B981', fontSize: 10, marginTop: 2, fontStyle: 'italic' },

  // Diagnosis options
  diagOption: { flexDirection: 'row', alignItems: 'center', gap: 10, backgroundColor: '#1E293B', padding: 12, borderRadius: 10, borderWidth: 1, borderColor: '#334155' },
  diagText: { color: '#E2E8F0', fontSize: 14, flex: 1 },

  // Interruption
