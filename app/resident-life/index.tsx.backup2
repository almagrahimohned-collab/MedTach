  pearlText: { color: '#94A3B8', fontSize: 12, paddingVertical: 3, lineHeight: 18 },
  levelUp: { backgroundColor: '#10B98120', padding: 16, borderRadius: 14, borderWidth: 1, borderColor: '#10B98140', marginTop: 8, width: '100%', alignItems: 'center' },
  levelUpText: { color: '#10B981', fontSize: 20, fontWeight: '800' },
  levelUpSubtext: { color: '#F8FAFC', fontSize: 14, marginTop: 4 },
  achSection: { backgroundColor: '#F59E0B15', padding: 12, borderRadius: 10, marginTop: 8, width: '100%' },
  achTitle: { color: '#F59E0B', fontSize: 13, fontWeight: '700', marginBottom: 4 },
  achText: { color: '#F8FAFC', fontSize: 13, paddingVertical: 1 },

  // Header
  header: { flexDirection: 'row', alignItems: 'center', padding: 12, paddingTop: 18, backgroundColor: '#1A1F2E', borderBottomWidth: 1, borderBottomColor: '#1E293B', gap: 8 },
  headerTitle: { color: '#F8FAFC', fontSize: 15, fontWeight: '700' },
  headerTime: { color: '#94A3B8', fontSize: 11 },
  headerBtns: { flexDirection: 'row', gap: 6, alignItems: 'center' },
  smallBtn: { backgroundColor: '#334155', paddingHorizontal: 8, paddingVertical: 5, borderRadius: 6 },
  smallBtnText: { color: '#FFF', fontSize: 12, fontWeight: '700' },
  suggestBtn: { flexDirection: 'row', alignItems: 'center', backgroundColor: '#F59E0B20', paddingHorizontal: 8, paddingVertical: 5, borderRadius: 6, gap: 4, borderWidth: 1, borderColor: '#F59E0B40' },
  suggestText: { color: '#F59E0B', fontSize: 10, fontWeight: '700' },
  headerStat: { color: '#F59E0B', fontSize: 11, fontWeight: '700', backgroundColor: '#1E293B', paddingHorizontal: 6, paddingVertical: 3, borderRadius: 6, overflow: 'hidden' },
  queueBadge: { color: '#F59E0B', fontSize: 11, fontWeight: '700', backgroundColor: '#F59E0B20', paddingHorizontal: 6, paddingVertical: 3, borderRadius: 6, overflow: 'hidden' },

  // Overlay
  overlay: { position: 'absolute', top: 0, left: 0, right: 0, bottom: 0, backgroundColor: 'rgba(0,0,0,0.9)', zIndex: 100, justifyContent: 'center', alignItems: 'center', gap: 12 },
